{
  "name": "timoxiter-workspace",
  "version": "1.0.0",
  "description": "TIMOXITER Discord Bot & Dashboard Workspace",
  "main": "index.js",
  "scripts": {
    "postinstall": "npm install --prefix backend",
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "backend": "npm start --prefix backend",
    "backend-dev": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "dev": "concurrently \"npm run backend-dev\" \"npm run frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
